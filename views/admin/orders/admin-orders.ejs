<%- include('../../Shared/includes/head', { pageTitle: 'Manage Orders' }) %>
<link rel="stylesheet" href="/styles/orders.css">
</head>
<body>
    <%- include('../../Shared/includes/header') %>
    
    <main>
        <h1>Manage All Orders</h1>
        
        <% if (orders && orders.length > 0) { %>
            <ul id="orders-list">
                <% for (const order of orders) { %>
                    <li class="order-item">
                        <h2>Order #<%= order.id %></h2>
                        
                        <div class="order-details">
                            <p><strong>Customer:</strong> <%= order.userData.name %> (<a href="mailto:<%= order.userData.email %>"><%= order.userData.email %></a>)</p>
                            <p><strong>Date:</strong> <time datetime="<%= order.date.toISOString() %>"><%= order.formattedDate %></time></p>
                            <p><strong>Total Price:</strong> $<%= order.productData.totalPrice.toFixed(2) %></p>
                        </div>

                        <section class="order-actions">
                            <form action="/admin/orders/<%= order.id %>" method="POST">
                                <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">
                                
                                <select name="newStatus" required>
                                    <option value="pending" <% if (order.status === 'pending') { %>selected<% } %>>Pending</option>
                                    <option value="fulfilled" <% if (order.status === 'fulfilled') { %>selected<% } %>>Fulfilled</option>
                                    <option value="cancelled" <% if (order.status === 'cancelled') { %>selected<% } %>>Cancelled</option>
                                </select>
                                
                                <button class="btn">Update Status</button>
                            </form>
                        </section>
                        <hr>
                    </li>
                <% } %>
            </ul>
        <% } else { %>
            <p>There are no orders in the database yet.</p>
        <% } %>
    </main>

<%- include('../../Shared/includes/footer') %>