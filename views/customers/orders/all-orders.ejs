<%- include('../../Shared/includes/head', { pageTitle: 'All Orders' }) %>
<link rel="stylesheet" href="/styles/orders.css">
</head>
<body>
    <%- include('../../Shared/includes/header') %>
    
    <main>
        <h1>All Your Orders</h1>
        
        <% if (locals.orders && locals.orders.length > 0) { %>
            <ul id="orders-list">
                <% for (const order of locals.orders) { %>
                    <li class="order-item">
                        <h2>Order #<%= order.id %></h2>
                        <p><strong>Status:</strong> <span class="order-status"><%= order.status %></span></p>
                        <p><strong>Date:</strong> <time datetime="<%= order.date.toISOString() %>"><%= order.formattedDate %></time></p>
                        <p><strong>Total Price:</strong> $<%= order.productData.totalPrice.toFixed(2) %></p>
                        <hr>
                    </li>
                <% } %>
            </ul>
        <% } else { %>
            <p>You have no orders yet!</p>
        <% } %>
    </main>

<%- include('../../Shared/includes/footer') %>